<?xml version="1.0" encoding="utf-8"?>
<!--
    Window background shown during the cold-start transition between the
    OS launching the activity and Compose rendering its first frame.

    Without this, `windowBackground` was @color/black, producing the
    several-hundred-ms all-black flash users see on first launch.
    Putting the duck here means the splash matches BootRegistrationScreen
    (same duck, centered) so the handoff to Compose looks continuous
    instead of black → branded.

    "dumb.co" wordmark isn't included here — layer-list can't render
    text. It pops in the moment BootRegistrationScreen composes, directly
    below the duck. If you want the wordmark in the splash itself, drop
    a wordmark vector at @drawable/dumb_co_wordmark and add a second
    <item> below this one with android:gravity="center" plus a top-margin
    offset.
-->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:drawable="@color/black" />
    <item
        android:drawable="@drawable/duck_app_icon"
        android:gravity="center"
        android:width="192dp"
        android:height="192dp" />
</layer-list>
