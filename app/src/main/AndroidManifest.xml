<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="com.offlineinc.dumbdownlauncher">

    <uses-permission android:name="android.permission.READ_CONTACTS"/>
    <uses-permission android:name="android.permission.WRITE_CONTACTS"/>
    <uses-permission android:name="android.permission.INTERNET"/>
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE"/>
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION"/>
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION"/>
    <uses-permission android:name="android.permission.ACCESS_BACKGROUND_LOCATION"/>
    <!-- Wi-Fi scanning for BeaconDB geolocation. Works on phones that have
         no Network Location Provider (e.g. MediaTek/TCL builds without Play
         Services) by sending nearby BSSIDs to a Mozilla-style API. -->
    <uses-permission android:name="android.permission.ACCESS_WIFI_STATE"/>
    <uses-permission android:name="android.permission.CHANGE_WIFI_STATE"/>
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS"/>
    <uses-permission android:name="android.permission.REQUEST_INSTALL_PACKAGES"/>
    <!-- Foreground service permissions removed — Type Sync relay now runs
         inside MouseAccessibilityService (no notification needed). -->
    <uses-permission android:name="android.permission.READ_PHONE_STATE"/>
    <uses-permission android:name="android.permission.READ_PHONE_NUMBERS"/>
    <!-- Required by TelephonyManager.sendUssdRequest in the USSD fallback path
         inside PhoneNumberReader for devices where Settings.Secure.device_phone_number
         was never written by automated_configuration.sh. PhoneNumberReader
         self-grants this at runtime via `su -c "pm grant …"` if the user hasn't
         granted it through the normal runtime-permission flow. -->
    <uses-permission android:name="android.permission.CALL_PHONE"/>
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE"
        android:maxSdkVersion="32" />

    <!-- Read pairing data from contact-sync app (legacy migration) -->
    <uses-permission android:name="com.offlineinc.dumbcontactsync.DEVICE_LINK_READ"/>

    <!-- Signature-level permission: only apps signed with the same key can read pairing data -->
    <permission
        android:name="com.offlineinc.dumbdownlauncher.DEVICE_LINK_READ"
        android:protectionLevel="signature" />

    <application
        android:name=".DumbDownApp"
        android:allowBackup="true"
        android:persistent="true"
        android:label="Dumb Launcher"
        android:icon="@mipmap/ic_launcher"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.DumbDownLauncher">

        <activity
            android:name=".MainAppsGridActivity"
            android:exported="false" />

        <activity
            android:name=".AllAppsActivity"
            android:exported="false" />

        <activity
            android:name=".WebViewActivity"
            android:exported="false"
            android:theme="@android:style/Theme.NoTitleBar.Fullscreen" />

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:launchMode="singleTask"
            android:taskAffinity=""
            android:excludeFromRecents="true">

            <!-- Makes it a HOME launcher -->
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.HOME" />
                <category android:name="android.intent.category.DEFAULT" />
            </intent-filter>

            <!-- Makes it runnable from Android Studio + visible in app list -->
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>

        </activity>

        <activity
            android:name=".notifications.ui.NotificationsActivity"
            android:exported="false" />

        <activity
            android:name=".contactsync.ContactSyncActivity"
            android:exported="false"
            android:launchMode="singleTop"
            android:noHistory="true"
            android:theme="@style/Theme.DumbDownLauncher" />

        <activity
            android:name=".quack.QuackActivity"
            android:exported="false"
            android:launchMode="singleTop"
            android:noHistory="true"
            android:theme="@style/Theme.DumbDownLauncher" />

        <activity
            android:name=".snake.SnakeActivity"
            android:exported="false"
            android:launchMode="singleTop"
            android:theme="@style/Theme.DumbDownLauncher" />

        <activity
            android:name=".weather.WeatherActivity"
            android:exported="false"
            android:launchMode="singleTop"
            android:noHistory="true"
            android:theme="@style/Theme.DumbDownLauncher" />

        <service
            android:name=".MouseAccessibilityService"
            android:permission="android.permission.BIND_ACCESSIBILITY_SERVICE"
            android:exported="true">
            <intent-filter>
                <action android:name="android.accessibilityservice.AccessibilityService" />
            </intent-filter>
            <meta-data
                android:name="android.accessibilityservice"
                android:resource="@xml/mouse_service_config" />
        </service>

        <!-- WebKeyboardService removed — relay moved into MouseAccessibilityService -->

        <!--
            Manages the Presentation window on the 128×128 cover display.
            Started from DumbDownApp — no foreground notification needed since
            the launcher process is protected by the HOME intent category.
        -->
        <service
            android:name=".coverdisplay.CoverDisplayService"
            android:exported="false" />

        <service
            android:name=".notifications.DumbNotificationListenerService"
            android:permission="android.permission.BIND_NOTIFICATION_LISTENER_SERVICE"
            android:exported="false">
            <intent-filter>
                <action android:name="android.service.notification.NotificationListenerService" />
            </intent-filter>
        </service>

        <receiver
            android:name=".update.DownloadAndInstallReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="com.offlineinc.dumbdownlauncher.action.DOWNLOAD_APK" />
                <action android:name="android.intent.action.DOWNLOAD_COMPLETE" />
            </intent-filter>
        </receiver>

        <!-- Receives star-key long-press broadcast from FlipMouse daemon -->
        <receiver
            android:name=".TypeSyncToggleReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="com.offlineinc.dumbdownlauncher.TOGGLE_TYPESYNC" />
            </intent-filter>
        </receiver>

        <!-- Monday 9am Eastern quack reminder alarm -->
        <receiver
            android:name=".quack.QuackMondayAlarmReceiver"
            android:exported="false">
            <intent-filter>
                <action android:name="com.offlineinc.dumbdownlauncher.QUACK_MONDAY" />
            </intent-filter>
        </receiver>

        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_provider_paths" />
        </provider>

        <!-- Exposes device-link pairing state to the contact-sync app.
             Both apps are signed with the same key on the TCL Flip Go. -->
        <provider
            android:name=".pairing.DeviceLinkProvider"
            android:authorities="com.offlineinc.dumbdownlauncher.devicelink"
            android:exported="true"
            android:readPermission="com.offlineinc.dumbdownlauncher.DEVICE_LINK_READ" />

    </application>

    <queries>
        <package android:name="com.whatsapp" />
        <package android:name="com.ubercab" />
        <package android:name="com.android.chrome" />

        <intent>
            <action android:name="android.intent.action.MAIN" />
            <category android:name="android.intent.category.LAUNCHER" />
        </intent>
    </queries>
</manifest>
